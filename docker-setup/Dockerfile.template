# Template dùng chung cho từng Spring Boot service khi scaffold monorepo (mục 10 checklist CLAUDE.md).
# Copy vào từng service (gateway/, user/, inventory/, recipe/, matching/, rag/, image/, payment/), không sửa file này trực tiếp.

FROM maven:3.9-eclipse-temurin-21 AS build
WORKDIR /app
COPY pom.xml .
COPY src ./src
RUN mvn -q -DskipTests package

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /app/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
